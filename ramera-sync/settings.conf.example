# ramera-sync settings.conf
# Format: key=value
# Lists are comma-separated values.
# Empty value means None for optional fields.

scan.cidr=192.168.1.0/24
scan.ports=80,443,554,8000
scan.connect_timeout_ms=600
scan.concurrency=128

nvr.username=
nvr.password=
nvr.record_paths=/ISAPI/System/deviceInfo,/ISAPI/ContentMgmt/record/tracks,/cgi-bin/magicBox.cgi?action=getSystemInfo,/api/records
nvr.request_timeout_ms=1500
nvr.include_https=true

scheduler.interval_seconds=300

# Download chunk size limit (in MB) to prevent crashing on low-resource PCs
# Recommended: 100-500 MB
download.max_chunk_size_mb=500
# Cloud sync clip length in seconds (0 = full record)
download.sync_clip_seconds=0

b2.key_id=${B2_KEY_ID}
b2.application_key=${B2_APPLICATION_KEY}
b2.bucket_id=${B2_BUCKET_ID}
b2.file_prefix=ramera/nvr-snapshots
b2.api_base=https://api.backblazeb2.com
b2.max_retentation_days=7
b2.upload_lag_days=1

# Suppress progress/tracing logs (true/false)
zero_log=false
